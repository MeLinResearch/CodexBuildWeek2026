{
  "$id": "https://release-assurance.local/contracts/run_status.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "live",
        "fixture"
      ]
    },
    "provenance": {
      "$ref": "provenance.schema.json"
    },
    "run_id": {
      "pattern": "^RUN-[0-9]{3}$",
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "state": {
      "enum": [
        "CREATED",
        "INGESTED",
        "MANIFEST_READY",
        "TESTS_GENERATED",
        "EXECUTED",
        "TRIAGED",
        "PATCH_PENDING",
        "PATCH_APPROVED",
        "PATCH_REJECTED",
        "RERUNNING",
        "EVIDENCE_READY",
        "DONE",
        "FAILED"
      ]
    },
    "updated_at": {
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "state",
    "mode",
    "schema_version",
    "created_at",
    "updated_at",
    "provenance"
  ],
  "type": "object"
}
